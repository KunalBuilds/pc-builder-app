<?xml version="1.0" encoding="utf-8"?>
<!-- Home Dashboard — PC Architect · Stitch Export · Apple Glass UI -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- ============================================================
         TOP APP BAR — Glass / Frosted (Apple iOS style)
         #FAF9FE/80 with backdrop visual via elevation
    ============================================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/surface_container_low"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:elevation="0dp"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/pc_builder_icon"
            android:scaleType="centerCrop" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="PC ARCHITECT"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@null"
            app:titleTextColor="@color/on_surface" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ============================================================
                 HERO SECTION — mesh gradient with editorial typography
            ============================================================ -->
            <LinearLayout
                android:id="@+id/heroLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_gradient"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_margin="16dp"
                android:elevation="2dp">

                <!-- AI badge chip -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/tertiary_fixed"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✦  System Online"
                        android:textColor="@color/on_tertiary_fixed"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />
                </LinearLayout>

                <!-- Display headline -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back,\nArchitect."
                    android:textColor="@color/on_surface"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    android:lineSpacingMultiplier="1.1"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your rig is in top 8% of class. Ready to push limits today?"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="20dp" />

                <!-- Hero action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnViewStats"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        android:text="View Live Stats"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_primary"
                        android:background="@drawable/btn_neon_gradient"
                        android:stateListAnimator="@null" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRigHistory"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Rig History"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        app:backgroundTint="@color/surface_container_high"
                        app:cornerRadius="100dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- ============================================================
                 SECTION LABEL
            ============================================================ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CORE ACTIONS"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:paddingHorizontal="20dp"
                android:paddingBottom="12dp" />

            <!-- ============================================================
                 ACTION CARD 1 — Architect Your PC
                 White card · primary-fixed icon tile · blue accent
            ============================================================ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnMakeNewPC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="24dp">

                    <!-- Icon tile -->
                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_tile">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🖥️"
                            android:textSize="26sp" />
                    </LinearLayout>

                    <!-- Text column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BUILD"
                            android:textColor="@color/primary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Architect Your PC"
                            android:textColor="@color/on_surface"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Design your next masterpiece with AI precision."
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>

                    <!-- Chevron -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/primary"
                        android:textSize="28sp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ============================================================
                 ACTION CARD 2 — Benchmark Your Rig
                 secondary-fixed icon tile · secondary accent
            ============================================================ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnComparePC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="24dp">

                    <!-- Icon tile — secondary-fixed -->
                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:gravity="center"
                        android:background="#FFE2DFFF">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏆"
                            android:textSize="26sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ANALYZE"
                            android:textColor="@color/secondary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Benchmark Your Rig"
                            android:textColor="@color/on_surface"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI scores + FPS predictions for your build."
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/secondary"
                        android:textSize="28sp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ============================================================
                 ACTION CARD 3 — Help & AI Chat
                 tertiary-fixed icon tile · tertiary accent
            ============================================================ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="24dp">

                    <!-- Icon tile — tertiary-fixed (ochre/copper) -->
                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:gravity="center"
                        android:background="#FFFFDBCC">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬"
                            android:textSize="26sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SUPPORT"
                            android:textColor="@color/tertiary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Help &amp; AI Chat"
                            android:textColor="@color/on_surface"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ask our Gemini AI · Expert PC advice."
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/tertiary"
                        android:textSize="28sp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ============================================================
                 SECONDARY INSIGHTS — Active config panel
                 (Tonal surface_container_low section)
            ============================================================ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_container_low"
                android:orientation="horizontal"
                android:padding="24dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp">

                <!-- Left stat column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE CONFIGURATION"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Build #1"
                        android:textColor="@color/on_surface"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01"
                        android:layout_marginBottom="16dp" />

                    <!-- Stat tiles row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardBackgroundColor="@color/surface_container_lowest"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="CPU TEMP" android:textColor="@color/on_surface_variant"
                                    android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.15" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="32°C" android:textColor="@color/on_surface"
                                    android:textSize="26sp" android:textStyle="bold" android:letterSpacing="-0.02" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/surface_container_lowest"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="FAN RPM" android:textColor="@color/on_surface_variant"
                                    android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.15" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="1,240" android:textColor="@color/on_surface"
                                    android:textSize="26sp" android:textStyle="bold" android:letterSpacing="-0.02" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
