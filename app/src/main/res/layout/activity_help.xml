<?xml version="1.0" encoding="utf-8"?>
<!-- AI Chat — Stitch "PC Architect Explorer" -->
<!-- HTML ref: ai_chat/code.html -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- TOP APP BAR — glass/frosted: bg-slate-50/80 backdrop-blur-xl -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/surface_container_low"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:orientation="horizontal"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PC ARCHITECT"
            android:textColor="@color/primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

        <!-- Status badge: "AI Chat" active nav item in header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/primary_fixed"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI CHAT"
                android:textColor="@color/primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/pc_builder_icon"
            android:scaleType="centerCrop" />
    </LinearLayout>

    <!-- CHAT MESSAGES AREA -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- ============================================================
         SUGGESTION CHIPS + INPUT BAR
         bg-white/70 backdrop-blur-2xl rounded-t-[24px]
    ============================================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_container_low">

        <!-- Suggestion chips horizontal scroll -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipCompareCPU"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Compare CPUs"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@color/surface_container_highest"
                    android:paddingHorizontal="14dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipRecommendGPU"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Recommend a GPU"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@color/surface_container_highest"
                    android:paddingHorizontal="14dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipPSUCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Power Supply Check"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@color/surface_container_highest"
                    android:paddingHorizontal="14dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipBottleneck"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Bottleneck Test"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@color/surface_container_highest"
                    android:paddingHorizontal="14dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- INPUT BAR — contains attach + text input + send button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="20dp">

            <!-- Input field: bg-surface-container-low rounded-2xl -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                app:cardBackgroundColor="@color/surface_container_highest"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMessage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Ask your hardware architect..."
                    android:textColorHint="@color/outline"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:background="@null"
                    android:paddingHorizontal="16dp"
                    android:inputType="text"
                    android:imeOptions="actionSend" />
            </androidx.cardview.widget.CardView>

            <!-- Send button: bg-primary rounded-2xl w-12 h-12 -->
            <LinearLayout
                android:id="@+id/btnSend"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:background="@drawable/btn_neon_gradient"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➤"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
