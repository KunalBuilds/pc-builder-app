<?xml version="1.0" encoding="utf-8"?>
<!-- Compare Builds — Stitch "PC Architect Explorer" -->
<!-- HTML ref: compare_builds/code.html -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- TOP APP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/surface_container_low"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:orientation="horizontal"
        android:elevation="4dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PC ARCHITECT"
            android:textColor="@color/primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:letterSpacing="0.04" />
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/pc_builder_icon"
            android:scaleType="centerCrop" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <!-- ============================================================
                 HEADER SECTION
            ============================================================ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM COMPARISON"
                android:textColor="@color/primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Build Confrontation"
                android:textColor="@color/on_surface"
                android:textSize="34sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Surgical precision in component matching. Evaluate thermal efficiency, compute power, and value between top two configurations."
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="28dp" />

            <!-- ============================================================
                 BUILD 1 — "Configuration A" (primary badge)
                 bg-surface-container-lowest rounded-2xl
            ============================================================ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Config A badge (top-right) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end"
                        android:layout_marginBottom="12dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@color/primary_container"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CONFIGURATION A"
                                android:textColor="@color/on_primary_container"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Build image preview -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:src="@drawable/home_hero_banner"
                        android:scaleType="centerCrop"
                        android:background="@color/surface_container_low"
                        android:layout_marginBottom="16dp" />

                    <!-- Name + price -->
                    <TextView
                        android:id="@+id/tvBuild1Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Build A"
                        android:textColor="@color/on_surface"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Focused on acoustics and workstation stability."
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvBuild1Cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textColor="@color/primary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02"
                        android:layout_marginBottom="20dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BUILD 1 SPECS LIST -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_container_low"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <!-- CPU row — highlighted with blue bg -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/surface_container_lowest"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="PROCESSOR" android:textColor="@color/on_surface_variant"
                            android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.2"
                            android:layout_marginBottom="2dp" />
                        <TextView android:id="@+id/tvBuild1CPU" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="@color/on_surface" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💻" android:textSize="20sp" />
                </LinearLayout>

                <!-- GPU row — blue highlighted (best spec) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/primary_fixed"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="GRAPHICS" android:textColor="@color/primary"
                            android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.2"
                            android:layout_marginBottom="2dp" />
                        <TextView android:id="@+id/tvBuild1GPU" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="@color/on_surface" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="+12% FPS" android:textColor="@color/primary"
                            android:textSize="10sp" android:textStyle="bold"
                            android:background="@color/surface_container_low"
                            android:paddingHorizontal="7dp" android:paddingVertical="3dp"
                            android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🎮" android:textSize="18sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- RAM row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/surface_container_lowest"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="MEMORY" android:textColor="@color/on_surface_variant"
                            android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.2"
                            android:layout_marginBottom="2dp" />
                        <TextView android:id="@+id/tvBuild1RAM" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="@color/on_surface" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🧠" android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ============================================================
                 BUILD 2 — "Configuration B"
            ============================================================ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="20dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end"
                        android:layout_marginBottom="12dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@color/surface_container_highest"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CONFIGURATION B"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1" />
                        </LinearLayout>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:src="@drawable/gpu_rtx_4070"
                        android:scaleType="centerCrop"
                        android:background="@color/surface_container_low"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvBuild2Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Build B"
                        android:textColor="@color/on_surface"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maximum throughput for 4K rendering pipelines."
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvBuild2Cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textColor="@color/on_surface"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02"
                        android:layout_marginBottom="20dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BUILD 2 SPECS LIST -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_container_low"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/primary_fixed"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="PROCESSOR" android:textColor="@color/primary"
                            android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.2"
                            android:layout_marginBottom="2dp" />
                        <TextView android:id="@+id/tvBuild2CPU" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="@color/on_surface" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Best Value" android:textColor="@color/primary"
                            android:textSize="10sp" android:textStyle="bold"
                            android:background="@color/surface_container_low"
                            android:paddingHorizontal="7dp" android:paddingVertical="3dp"
                            android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💻" android:textSize="18sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/surface_container_lowest"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="GRAPHICS" android:textColor="@color/on_surface_variant"
                            android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.2"
                            android:layout_marginBottom="2dp" />
                        <TextView android:id="@+id/tvBuild2GPU" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="@color/on_surface" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎮" android:textSize="20sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/surface_container_lowest"
                    android:padding="14dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="MEMORY" android:textColor="@color/on_surface_variant"
                            android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.2"
                            android:layout_marginBottom="2dp" />
                        <TextView android:id="@+id/tvBuild2RAM" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="@color/on_surface" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🧠" android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ============================================================
                 PERFORMANCE METRICS TABLE — bg-surface-container-lowest rounded-3xl
            ============================================================ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Performance Metrics"
                        android:textColor="@color/on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01"
                        android:layout_marginBottom="20dp" />

                    <!-- Table header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="ATTRIBUTE"
                            android:textColor="@color/on_surface_variant" android:textSize="9sp"
                            android:textStyle="bold" android:letterSpacing="0.2" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="BUILD A"
                            android:textColor="@color/on_surface_variant" android:textSize="9sp"
                            android:textStyle="bold" android:letterSpacing="0.2" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="BUILD B"
                            android:textColor="@color/on_surface_variant" android:textSize="9sp"
                            android:textStyle="bold" android:letterSpacing="0.2" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/surface_container" android:layout_marginBottom="12dp" />

                    <!-- Row 1: Cinebench -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingVertical="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="Cinebench R23"
                            android:textColor="@color/on_surface" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvCinebench1" android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="—"
                            android:textColor="@color/primary" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvCinebench2" android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="—"
                            android:textColor="@color/on_surface" android:textSize="13sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/surface_container" />

                    <!-- Row 2: TimeSpy -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingVertical="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="TimeSpy Extreme"
                            android:textColor="@color/on_surface" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvTimeSpy1" android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="—"
                            android:textColor="@color/primary" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvTimeSpy2" android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="—"
                            android:textColor="@color/on_surface" android:textSize="13sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/surface_container" />

                    <!-- Row 3: Noise -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingVertical="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="Peak Noise"
                            android:textColor="@color/on_surface" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvNoise1" android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="—"
                            android:textColor="@color/on_surface" android:textSize="13sp" />
                        <TextView android:id="@+id/tvNoise2" android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="—"
                            android:textColor="@color/primary" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/surface_container" />

                    <!-- Row 4: TDP -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingVertical="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="Idle TDP"
                            android:textColor="@color/on_surface" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvTdp1" android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="—"
                            android:textColor="@color/on_surface" android:textSize="13sp" />
                        <TextView android:id="@+id/tvTdp2" android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="—"
                            android:textColor="@color/primary" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ============================================================
                 AI ACTION BUTTONS
            ============================================================ -->
            <!-- AI Choose button: bg-tertiary-container -->
            <Button
                android:id="@+id/btnAIChoose"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="🤖  LET AI CHOOSE BEST VALUE"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/on_tertiary_container"
                android:backgroundTint="@color/tertiary_container"
                app:cornerRadius="100dp"
                android:stateListAnimator="@null" />

            <!-- Confirm Build button: gradient pill -->
            <Button
                android:id="@+id/btnConfirmBuild"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="CONFIRM BUILD SELECTION"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.05"
                android:background="@drawable/btn_neon_gradient"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
