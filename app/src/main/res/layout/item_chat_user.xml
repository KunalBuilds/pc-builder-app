<?xml version="1.0" encoding="utf-8"?>
<!-- User Chat Bubble — Stitch ai_chat/code.html style -->
<!-- Matches: .bg-primary text-on-primary p-5 rounded-2xl rounded-br-none -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="end"
    android:paddingVertical="6dp"
    android:paddingStart="60dp">

    <!-- User bubble: bg-primary text-on-primary -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:layout_gravity="end">
        <TextView
            android:id="@+id/tvUserMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4" />
    </LinearLayout>

    <!-- "Delivered" status: text-[10px] font-bold tracking-widest text-outline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:text="Delivered"
        android:textColor="@color/outline"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp" />
</LinearLayout>
