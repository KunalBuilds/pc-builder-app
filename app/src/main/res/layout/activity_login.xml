<?xml version="1.0" encoding="utf-8"?>
<!-- Login Screen — PC Architect · Stitch Export · Apple Glass UI -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Hero image: top 40% (≈320dp) of screen -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:src="@drawable/login_hero_bg"
        android:scaleType="centerCrop"
        android:layout_gravity="top" />

    <!-- Dark-to-transparent gradient fade over hero bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="@drawable/bg_fade_bottom"
        android:layout_gravity="top" />

    <!-- Full scroll content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero branding section — overlaid on image, 260dp tall -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:orientation="vertical"
                android:gravity="bottom|start"
                android:paddingStart="24dp"
                android:paddingBottom="28dp">

                <!-- Precision badge pill -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/badge_precision"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Precision Architect"
                        android:textColor="#ADC6FF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2" />
                </LinearLayout>

                <!-- App name headline -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PC\nARCHITECT"
                    android:textColor="#FFFFFF"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    android:lineSpacingMultiplier="1.0"
                    android:layout_marginBottom="10dp" />

                <!-- Tagline -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Orchestrate high-performance systems\nwith AI-driven precision."
                    android:textColor="#99FFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <!-- Login form section — white card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface_container_low"
                android:paddingHorizontal="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="32dp">

                <!-- Glass card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_container_lowest"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="28dp">

                        <!-- Card header -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Welcome Back"
                            android:textColor="@color/on_surface"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Access your digital hardware atelier."
                            android:textColor="@color/on_surface_variant"
                            android:textSize="14sp"
                            android:layout_marginBottom="28dp" />

                        <!-- Email Field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Email Address"
                            app:boxBackgroundColor="@color/surface_container_highest"
                            app:boxStrokeColor="@color/primary"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="2dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:inputType="textEmailAddress"
                                android:imeOptions="actionNext"
                                android:textColor="@color/on_surface"
                                android:textColorHint="@color/on_surface_variant"
                                android:background="@null" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Spacer -->
                        <View android:layout_width="0dp" android:layout_height="16dp" />

                        <!-- Password Field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Password"
                            app:passwordToggleEnabled="true"
                            app:passwordToggleTint="@color/on_surface_variant"
                            app:boxBackgroundColor="@color/surface_container_highest"
                            app:boxStrokeColor="@color/primary"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="2dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPassword"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:inputType="textPassword"
                                android:imeOptions="actionDone"
                                android:textColor="@color/on_surface"
                                android:textColorHint="@color/on_surface_variant"
                                android:background="@null" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Forgot password -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="4dp"
                            android:text="Forgot Password?"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />

                        <!-- Primary CTA — gradient pill button -->
                        <Button
                            android:id="@+id/btnEmailLogin"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="20dp"
                            android:text="LOGIN TO CONSOLE"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_primary"
                            android:letterSpacing="0.1"
                            android:background="@drawable/btn_neon_gradient"
                            android:stateListAnimator="@null" />

                        <!-- Loading spinner -->
                        <ProgressBar
                            android:id="@+id/progressBar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="8dp"
                            android:indeterminateTint="@color/primary"
                            android:visibility="gone" />

                        <!-- Ghost / outlined secondary button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCreateAccount"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="12dp"
                            android:text="REQUEST ACCESS"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textColor="@color/on_surface"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:strokeColor="@color/surface_container_highest"
                            app:strokeWidth="2dp"
                            app:cornerRadius="100dp" />

                        <!-- Google Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGoogleSignIn"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="8dp"
                            android:text="Continue with Google"
                            android:textSize="13sp"
                            android:textColor="@color/on_surface_variant"
                            app:icon="@android:drawable/ic_dialog_email"
                            app:iconTint="@null"
                            style="@style/Widget.Material3.Button.TextButton" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Trusted partners footer -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="28dp">
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/surface_variant" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="TRUSTED HARDWARE PARTNERS"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2" />
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/surface_variant" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
