<?xml version="1.0" encoding="utf-8"?>
<!-- AI Bot Chat Bubble — Stitch ai_chat/code.html style -->
<!-- Matches: .bg-surface-container-low p-5 rounded-2xl rounded-bl-none -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="bottom"
    android:paddingVertical="6dp"
    android:paddingEnd="60dp">

    <!-- Bot avatar: w-8 h-8 rounded-full bg-tertiary-container -->
    <LinearLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:background="@color/tertiary_fixed"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="2dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Message bubble -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_container_low"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:layout_weight="1">

        <!-- Bot name label: text-sm font-medium text-tertiary -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Architect AI"
            android:textColor="@color/tertiary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- Message text -->
        <TextView
            android:id="@+id/tvBotMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5" />
    </LinearLayout>
</LinearLayout>
