<?xml version="1.0" encoding="utf-8"?>
<!-- Build Result Component Card — Stitch build_result/code.html -->
<!-- Matches: .rounded-3xl p-6 flex items-center gap-6 bg-surface-container-lowest -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginBottom="12dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface_container_lowest"
        app:cardCornerRadius="24dp"
        app:cardElevation="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp">

            <!-- Component image: w-20 h-20 bg-surface-container-low rounded-2xl -->
            <androidx.cardview.widget.CardView
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/ivComponent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/pc_builder_icon"
                    android:scaleType="centerCrop"
                    android:padding="8dp" />
            </androidx.cardview.widget.CardView>

            <!-- Component info (center) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <!-- Type label: text-[10px] font-black uppercase text-primary -->
                <TextView
                    android:id="@+id/tvType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMPONENT"
                    android:textColor="@color/primary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="3dp" />

                <!-- Component name: text-xl font-extrabold -->
                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Component Name"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.01"
                    android:layout_marginBottom="6dp" />

                <!-- Spec 1 + Spec 2 row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="16dp">
                        <TextView
                            android:id="@+id/tvSpec1Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SPEC"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15" />
                        <TextView
                            android:id="@+id/tvSpec1Value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/on_surface"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvSpec2Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SPEC"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15" />
                        <TextView
                            android:id="@+id/tvSpec2Value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/on_surface"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Price + Buy button (right) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    android:layout_marginBottom="8dp" />

                <!-- Buy Now button: bg-on-surface text-surface rounded-full -->
                <Button
                    android:id="@+id/btnBuyNow"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Buy Now"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.08"
                    android:background="@color/on_surface"
                    android:paddingHorizontal="14dp"
                    android:stateListAnimator="@null"
                    style="@style/Widget.Material3.Button" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
