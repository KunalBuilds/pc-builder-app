<?xml version="1.0" encoding="utf-8"?>
<!-- Component List Item — Stitch component_selection/code.html (All Components list) -->
<!-- Matches: .flex items-center bg-surface-container-low p-4 rounded-2xl -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/surface_container_low"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Product image tile: h-16 w-16 rounded-xl bg-surface-container-lowest -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="64dp"
        android:layout_height="64dp"
        app:cardBackgroundColor="@color/surface_container_lowest"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp">
        <ImageView
            android:id="@+id/ivComponent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/pc_builder_icon"
            android:scaleType="centerCrop"
            android:padding="8dp" />
    </androidx.cardview.widget.CardView>

    <!-- Component info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <!-- Brand name + optional AI badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">

            <TextView
                android:id="@+id/tvBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BRAND"
                android:textColor="@color/outline"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginEnd="6dp" />

            <LinearLayout
                android:id="@+id/layoutAiBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/tertiary_fixed"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI RECOMMENDED"
                    android:textColor="@color/on_tertiary_fixed"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>
        </LinearLayout>

        <!-- Component name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Component Name"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Price + rating row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐"
                android:textSize="12sp"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.8"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Add button: h-10 w-10 rounded-full bg-surface-container-lowest -->
    <LinearLayout
        android:id="@+id/btnAdd"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:gravity="center"
        android:background="@color/surface_container_lowest"
        android:layout_marginStart="8dp"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:textColor="@color/on_surface_variant"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
