<?xml version="1.0" encoding="utf-8"?>
<!-- Apple Glass / Stitch "PC Architect" gradient button -->
<!-- Linear gradient: #0058BC → #0070EB at 135° (specular highlight effect) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#0058BC"
        android:endColor="#0070EB"
        android:angle="135"
        android:type="linear" />
    <corners android:radius="100dp" />
</shape>
