<?xml version="1.0" encoding="utf-8"?>
<!-- Hero mesh gradient: radial glow from primary-fixed for splash and hero sections -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#FFD8E2FF"
        android:endColor="#FFFAF9FE"
        android:angle="270"
        android:type="linear" />
    <corners android:radius="24dp" />
</shape>
