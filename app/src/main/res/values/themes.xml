<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- === PC ARCHITECT — Stitch / Apple Glass Theme === -->

    <!-- Primary app theme — LIGHT mode -->
    <style name="Theme.MyPCApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOutline">@color/outline</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.MyPCApp.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- Glass Card style — white card on light surface -->
    <style name="CardStyle.Glass" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_container_lowest</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Filled Card — surface_container_low -->
    <style name="CardStyle.Surface" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_container_low</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Primary Gradient Button (simulated via bg drawable) -->
    <style name="ButtonPrimary.Gradient" parent="Widget.Material3.Button">
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Ghost / Outlined button -->
    <style name="ButtonOutlined.Glass" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="strokeColor">@color/surface_container_highest</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <!-- Input field — Stitch style -->
    <style name="InputGlass" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_container_highest</item>
        <item name="boxStrokeColor">@color/surface_container_highest</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/on_surface_variant</item>
    </style>

    <!-- Chip — Stitch editorial pill -->
    <style name="ChipGlass" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface_container_high</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipCornerRadius">100dp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>
